<Window x:Class="PipelineIntervalSort.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PipelineIntervalSort"
             mc:Ignorable="d" Height="350" Width="500" Topmost="True" WindowStartupLocation="CenterScreen" Title="管线等间距排序">
    <Grid>
        <Grid x:Name="grid_mix_first"  HorizontalAlignment="Left" VerticalAlignment="Top" Margin="100,60,0,0" Visibility="Collapsed">
            <Label Content="水电混合: " HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0"/>
            <RadioButton IsChecked="True"  GroupName="group_mix" x:Name="rb_cable_first" Content="桥架优先" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="80,6,0,0"/>
            <RadioButton GroupName="group_mix" x:Name="rb_pipe_first" Content="管道优先" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="160,6,0,0"/>
        </Grid>

        <Label Content="排序方式: " HorizontalAlignment="Left" VerticalAlignment="Top" Margin="100,100,0,0"/>
        <RadioButton GroupName="group_type" Name="rb_min_to_max" Content="从小到大" IsChecked="True" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="180,106,0,0"/>
        <RadioButton GroupName="group_type" x:Name="rb_max_to_min" Content="从大到小" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="260,106,0,0"/>

        <Grid x:Name="grid_space" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="124,140,0,0">
            <Label Name="lb_dis" Content="间距: " HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0"/>
            <TextBox x:Name="tb_dis" Width="100" VerticalContentAlignment="Center" Height="20" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="58,0,0,0"/>
            <Label Name="lb_unit" Content="mm" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="158,0,0,0"/>
        </Grid>
        <Button Width="60" Height="25" HorizontalAlignment="Right" VerticalAlignment="Bottom" Content="确定" Margin="0,0,150,20" IsDefault="True" Click="Button_Click"/>
        <Button Width="60" Height="25" HorizontalAlignment="Right" VerticalAlignment="Bottom" Content="取消" Margin="0,0,60,20" IsCancel="True" Click="Button_Click_1"/>
        <Grid Name="grid_mix"  HorizontalAlignment="Left" VerticalAlignment="Top" Margin="180,106,0,0" Background="White" Visibility="Collapsed">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <Label VerticalAlignment="Center" Content="桥架" Height="15" VerticalContentAlignment="Center" Padding="0" Margin="0,0,10,0" FontSize="12"/>
                    <RadioButton x:Name="rb_cable_min_to_max" VerticalAlignment="Center" GroupName="rb_cable_sel" Content="从小到大" IsChecked ="True" Margin="0,0,13,0"/>
                    <RadioButton x:Name="rb_cable_max_to_min" VerticalAlignment="Center" GroupName="rb_cable_sel" Content="从大到小"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,25,0,0">
                    <Label VerticalAlignment="Center" Content="管道" Height="15" VerticalContentAlignment="Center" Padding="0" Margin="0,0,10,0" FontSize="12"/>
                    <RadioButton x:Name="rb_pipe_min_to_max" VerticalAlignment="Center" GroupName="rb_pipe_sel" Content="从小到大" IsChecked ="True" Margin="0,0,13,0"/>
                    <RadioButton x:Name="rb_pipe_max_to_min" VerticalAlignment="Center" GroupName="rb_pipe_sel" Content="从大到小"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
