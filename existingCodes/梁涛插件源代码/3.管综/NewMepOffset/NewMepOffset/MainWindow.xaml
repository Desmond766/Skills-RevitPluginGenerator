<Window x:Class="NewMepOffset.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NewMepOffset"
             mc:Ignorable="d" Height="480" Width="350" MinHeight="400" MinWidth="350" WindowStartupLocation="CenterScreen" Title="管线避让" KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.2*"/>
            <RowDefinition Height="0.2*"/>
            <RowDefinition Height="0.2*"/>
            <RowDefinition Height="0.2*"/>
            <RowDefinition Height="0.15*"/>
        </Grid.RowDefinitions>
        <GroupBox Grid.Row="0" Margin="10" Header="方向">
            <Grid x:Name="grid1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.5*"/>
                    <ColumnDefinition Width="0.5*"/>
                </Grid.ColumnDefinitions>
                <RadioButton GroupName="rbg_direction" Grid.Column="0" Content="升降" HorizontalAlignment="Center"  VerticalAlignment="Center" Click="RadioButton_Click"/>
                <RadioButton GroupName="rbg_direction" Grid.Column="1" Content="偏移" HorizontalAlignment="Center" VerticalAlignment="Center" Click="RadioButton_Click"/>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="1" Margin="10" Header="类型">
            <Grid x:Name="grid3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.5*"/>
                    <ColumnDefinition Width="0.5*"/>
                </Grid.ColumnDefinitions>
                <RadioButton GroupName="rbg_cate" Grid.Column="0" Content="单侧" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" Click="RadioButton_Click"/>
                <RadioButton GroupName="rbg_cate" Grid.Column="1" Content="两侧" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" Click="RadioButton_Click"/>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="2" Margin="10" Header="角度">
            <Grid x:Name="grid2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.2*"/>
                    <ColumnDefinition Width="0.2*"/>
                    <ColumnDefinition Width="0.2*"/>
                    <ColumnDefinition Width="0.2*"/>
                    <ColumnDefinition Width="0.2*"/>
                </Grid.ColumnDefinitions>
                <RadioButton GroupName="rbg_angle" Grid.Column="0" Content="15" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" Click="RadioButton_Click"/>
                <RadioButton GroupName="rbg_angle" Grid.Column="1" Content="30" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" Click="RadioButton_Click"/>
                <RadioButton GroupName="rbg_angle" Grid.Column="2" Content="45" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" Click="RadioButton_Click"/>
                <RadioButton GroupName="rbg_angle" Grid.Column="3" Content="60" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" Click="RadioButton_Click"/>
                <RadioButton GroupName="rbg_angle" Grid.Column="4" Content="90" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" Click="RadioButton_Click"/>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="3" Margin="10" Header="偏移距离">
            <ComboBox IsEditable="True" Margin="15" Name="cb_dis" VerticalAlignment="Center"/>
        </GroupBox>
        <Button IsDefault="True" Grid.Row="4" Content="确定" Height="25" Width="80" HorizontalAlignment="Left" Margin="10" Click="Button_Click_1"/>
        <Button x:Name="bt_cancel" Grid.Row="4" Content="取消" Height="25" Width="80" HorizontalAlignment="Right" Margin="10" Click="Button_Click"/>
    </Grid>
</Window>
