<Window x:Class="CutFloor.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CutFloor"
             mc:Ignorable="d" Height="256" Width="380" WindowStartupLocation="CenterScreen" Topmost="True" Title="拆分楼板">
    <Grid>
        <RadioButton x:Name="rb_num" IsChecked="True" Content="按指定个数拆分：" HorizontalAlignment="Left" Margin="80,70,0,0" VerticalAlignment="Top"/>
        <RadioButton Content="按指定间距拆分：" HorizontalAlignment="Left" Margin="80,95,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tb_num" Height="20" Width="60" Margin="195,67,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" VerticalContentAlignment="Center"/>
        <TextBox x:Name="tb_space" Height="20" Width="60" Margin="195,90,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" VerticalContentAlignment="Center"/>
        <Label Margin="262,63,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" VerticalContentAlignment="Center" Content="个"/>
        <Label Margin="262,88,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" VerticalContentAlignment="Center" Content="mm"/>
        <Button Height="25" Width="60" IsDefault="True" Content="确定" Margin="0,0,95,24" HorizontalAlignment="Right" VerticalAlignment="Bottom" Click="Button_Click"/>
        <Button Height="25" Width="60" IsCancel="True" Content="取消" Margin="0,0,19,24" HorizontalAlignment="Right" VerticalAlignment="Bottom" Click="Button_Click_1"/>

    </Grid>
</Window>
