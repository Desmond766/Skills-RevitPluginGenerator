<Window x:Class="FlippingBeam.ProgressBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlippingBeam"
             mc:Ignorable="d" WindowStartupLocation="CenterScreen" Height="283" Width="460">
    <Grid>
        <ProgressBar x:Name="pgb" Minimum="0" Maximum="100" HorizontalAlignment="Left" Height="41" Margin="75,75,0,0" VerticalAlignment="Top" Width="256" ValueChanged="pgb_ValueChanged"/>
        <Button Content="Button" HorizontalAlignment="Left" Margin="230,179,0,0" VerticalAlignment="Top" Click="Button_Click"/>

    </Grid>
</Window>
