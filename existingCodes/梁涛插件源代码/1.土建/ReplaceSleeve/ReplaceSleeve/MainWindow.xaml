<Window x:Class="ReplaceSleeve.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReplaceSleeve"
             mc:Ignorable="d" Width="400" Height="200" Title="一键替换结构柱" WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.3*"/>
            <RowDefinition Height="0.3*"/>
            <RowDefinition Height="0.3*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Label Content="原柱类型：" VerticalAlignment="Center" Margin="20,0,0,0"/>
            <ComboBox Name="cbb_old_type" Width="150" Height="25" VerticalAlignment="Center" HorizontalAlignment="Center" VerticalContentAlignment="Center"/>
        </Grid>
        <Grid Grid.Row="1">
            <Label Content="替换柱类型：" VerticalAlignment="Center" Margin="20,0,0,0"/>
            <ComboBox Name="cbb_new_type" Width="150" Height="25" VerticalAlignment="Center" HorizontalAlignment="Center" VerticalContentAlignment="Center"/>
        </Grid>
        <Button Grid.Row="2" Width="60" Height="25" Content="确定" IsDefault="True" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="230,0,0,0" Click="Button_Click"/>
        <Button Grid.Row="2" Width="60" Height="25" Content="取消" IsCancel="True" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="310,0,0,0" Click="Button_Click_1"/>

    </Grid>
</Window>
