<Window x:Class="CreateThresholdStone.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CreateThresholdStone"
             mc:Ignorable="d" Height="250" Width="250" WindowStartupLocation="CenterOwner" Title="创建门槛石">
    <Grid>
        <Label Content="门槛石厚度:" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,-20,0,0"/>
        <TextBox Text="50" x:Name="tb_thickness" Width="80" Height="25" HorizontalAlignment="Left" VerticalAlignment="Center" VerticalContentAlignment="Center" Margin="85,-20,0,0"/>
        <Label Content="mm" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="170,-20,0,0"/>
        <Button Width="60" Height="25" HorizontalAlignment="Right" VerticalAlignment="Bottom" Content="确定" IsDefault="True" Margin="0,0,100,20" Click="Button_Click"/>
        <Button Width="60" Height="25" HorizontalAlignment="Right" VerticalAlignment="Bottom" Content="取消" IsCancel="True" Margin="0,0,20,20" Click="Button_Click_1"/>
    </Grid>
</Window>
