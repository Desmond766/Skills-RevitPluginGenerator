<Window x:Class="ChangeDoorSymbolAngle.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ChangeDoorSymbolAngle"
             mc:Ignorable="d" Height="600" Width="600" WindowStartupLocation="CenterScreen" Title="修改门类型开启角度" MinWidth="550" MaxWidth="700">
    <Window.Resources>
        <ResourceDictionary>
            <Style x:Key="dgCell" TargetType="TextBlock">
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="ColumnHeaderStyleC" TargetType="DataGridColumnHeader">
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="ToolTip" Value="Click to sort."/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="0.2*"/>
        </Grid.RowDefinitions>
        <DataGrid AutoGenerateColumns="False" Grid.Row="0" Margin="5" Name="dataGrid" CanUserAddRows="False" CanUserDeleteRows="False" ItemsSource="{Binding}" ColumnHeaderStyle="{DynamicResource ColumnHeaderStyleC}" SelectionChanged="dataGrid_SelectionChanged"> 
            <DataGrid.Columns>
                <DataGridTextColumn Header="门族名称" IsReadOnly="True" Binding="{Binding FamilyName}"/>
                <DataGridTextColumn Header="门类型名称" IsReadOnly="True" Binding="{Binding SymbolName}"/>
                <DataGridTextColumn Header="参数名称" IsReadOnly="True" Binding="{Binding ParaName}" />
                <DataGridTextColumn Header="只读" IsReadOnly="True" Binding="{Binding IsReadOnlyToString}"  ElementStyle="{StaticResource dgCell}"/>
                <DataGridTemplateColumn Header="角度" IsReadOnly="True" x:Name="dgcb">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox Text="{Binding AngleValue, Mode=TwoWay}" TextBoxBase.TextChanged="cbb_angle_TextChanged" x:Name="cbb_angle" IsEditable="True" ItemsSource="{Binding DefaultAngles}" GotFocus="cbb_angle_GotFocus" PreviewTextInput="cbb_angle_PreviewTextInput"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.65*"/>
                <ColumnDefinition Width="0.35*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <CheckBox x:Name="chb_angle" Margin="5" Content="批量修改" VerticalAlignment="Center" Click="CheckBox_Click" IsChecked="True"/>
                <TextBox x:Name="tb_angle" Height="20" Margin="5" Width="100" VerticalContentAlignment="Center" VerticalAlignment="Center" IsReadOnly="False"/>
                <Button Height="20" Width="60" Content="修改" IsEnabled="True" Name="bt_angle" Click="bt_angle_Click"/>
                <Button Content="重置" Height="20" Width="60" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="5" Click="Button_Click_2"/>
            </StackPanel>
            <Button Content="确定" Grid.Column="1" Height="25" Width="60" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,100,0" Click="Button_Click"/>
            <Button Content="取消" Grid.Column="1" Height="25" Width="60" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0" Click="Button_Click_1"/>
        </Grid>
    </Grid>
</Window>
