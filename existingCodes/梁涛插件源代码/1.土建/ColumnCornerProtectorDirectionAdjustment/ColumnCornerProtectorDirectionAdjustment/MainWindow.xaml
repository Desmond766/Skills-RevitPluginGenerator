<Window x:Class="ColumnCornerProtectorDirectionAdjustment.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ColumnCornerProtectorDirectionAdjustment"
             mc:Ignorable="d" Height="120" Width="450" Topmost="True" WindowStartupLocation="CenterOwner" Title="自定义极限距离">
    <Grid>
        <Label Content="套柱距车道边界线最远距离：" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,0,0,0"/>
        <TextBox x:Name="tb_max_dis" HorizontalAlignment="Left" VerticalAlignment="Center" VerticalContentAlignment="Center" Margin="170,0,0,0" Width="60" Height="25"/>
        <Label Content="mm" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="240,0,0,0"/>
        <Button Content="确定" HorizontalAlignment="Left" Margin="290,0,0,0" VerticalAlignment="Center" Width="50" Height="20" IsDefault="True" Click="Button_Click"/>
        <Button Content="取消" HorizontalAlignment="Left" Margin="354,0,0,0" VerticalAlignment="Center" Width="50" Height="20" IsCancel="True" Click="Button_Click_1"/>
    </Grid>
</Window>
