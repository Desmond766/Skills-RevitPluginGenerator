<Window x:Class="ColoringOfStructuralPlates.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ColoringOfStructuralPlates"
             mc:Ignorable="d" Title="结构板赋色" WindowStartupLocation="CenterScreen" Height="176" Width="321" ResizeMode="NoResize">
    <Grid>
        <TabControl HorizontalAlignment="Center" Height="61" VerticalAlignment="Top" Width="260">
            <TabItem Header="楼板">
                <Grid Background="#FFE5E5E5">
                    <Button x:Name="level_btn" Content="根据顶部高程赋色" HorizontalAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center" Click="level_btn_Click"/>
                    <Button x:Name="high_btn" Content="根据板厚赋色" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center" Click="high_btn_Click" Width="113"/>
                </Grid>
            </TabItem>
        </TabControl>
        <TabControl HorizontalAlignment="Center" Height="61" VerticalAlignment="Top" Width="260" Margin="0,66,0,0">
            <TabItem Header="天花板">
                <Grid Background="#FFE5E5E5">
                    <Button Content="根据标高高度偏移赋色" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" Click="Button_Click"/>

                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
