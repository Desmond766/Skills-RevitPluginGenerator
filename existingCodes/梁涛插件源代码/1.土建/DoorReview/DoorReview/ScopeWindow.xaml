<Window x:Class="DoorReview.ScopeWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DoorReview"
             mc:Ignorable="d" Height="145" Width="598" Title="查找范围" Topmost="True" WindowStartupLocation="CenterScreen">
    <Grid>
        <Label Content="查找范围: " HorizontalAlignment="Left" Margin="50,-20,0,0" VerticalAlignment="Center"/>
        <TextBox Name="tb_scope" HorizontalAlignment="Left" Margin="120,-20,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="120"/>
        <Label Content="mm " HorizontalAlignment="Left" Margin="245,-20,0,0" VerticalAlignment="Center"/>
        <Button Content="重置" HorizontalAlignment="Left" Margin="299,-20,0,0" VerticalAlignment="Center" Width="60" Height="25" Click="Button_Click"/>
        <Button Content="确定" IsDefault="True" HorizontalAlignment="Left" Margin="420,70,0,0" VerticalAlignment="Top"  Width="60" Height="25" Click="Button_Click_1"/>
        <Button Content="取消" IsCancel="True" HorizontalAlignment="Left" Margin="490,70,0,0" VerticalAlignment="Top"  Width="60" Height="25" Click="Button_Click_2"/>
        <RadioButton x:Name="rb_full" Content="完整文字注释" HorizontalAlignment="Left" Margin="50,50,0,0" VerticalAlignment="Center" IsChecked="True"/>
        <RadioButton Content="不完整文字注释" HorizontalAlignment="Left" Margin="150,50,0,0" VerticalAlignment="Center"/>


    </Grid>
</Window>
