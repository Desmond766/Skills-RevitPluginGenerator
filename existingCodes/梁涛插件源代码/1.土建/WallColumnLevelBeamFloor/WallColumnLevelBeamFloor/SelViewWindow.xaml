<Window x:Class="WallColumnLevelBeamFloor.SelViewWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WallColumnLevelBeamFloor"
             mc:Ignorable="d" MinHeight="400" MaxHeight="600" MinWidth="200" MaxWidth="400" Height="450" Width="250" WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip" WindowStyle="None" AllowsTransparency="True" Background="#FFF0F0F0" BorderThickness="0.7" BorderBrush="Black">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" MouseMove="Grid_MouseMove" Background="White">
            <Label Content="跳转视图"/>
            <StackPanel Margin="0" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Width="30" Height="30" VerticalAlignment="Center" Cursor="Hand" ToolTip="关闭" MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave" Click="Button_Click_2" PreviewMouseDown="Button_PreviewMouseDown">
                    <Button.Template>
                        <ControlTemplate>
                            <Grid Background="Transparent">
                                <Line Width="10" Height="10" X1="0" Y1="0" X2="10" Y2="10" StrokeThickness="1" Stroke="Black" ></Line>
                                <Line Width="10" Height="10" X1="10" Y1="0" X2="0" Y2="10" StrokeThickness="1" Stroke="Black" ></Line>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
        <Label Grid.Row="1" Content="选择一个三维视图" HorizontalAlignment="Left" Margin="2" VerticalAlignment="Top"/>
        <Border x:Name="border_list"  Background="White" BorderThickness="0.5" BorderBrush="Black" Margin="15" Grid.Row="2">
            <StackPanel Margin="0">
                <ListBox DisplayMemberPath="View3DName" x:Name="list" Height="{Binding ActualHeight, ElementName=border_list, Mode=OneWay}"  Margin="0" MinHeight="250" MinWidth="150" BorderBrush="{x:Null}"/>
            </StackPanel>
        </Border>
        
        <Button IsDefault="True" Grid.Row="3" Margin="10" Width="70" Height="20" Content="跳转" HorizontalAlignment="Left" VerticalAlignment="Center" Click="Button_Click"/>
        <Button IsCancel="True" Grid.Row="3" Margin="10" Width="70" Height="20" Content="取消" HorizontalAlignment="Right" VerticalAlignment="Center" Click="Button_Click_1"/>
    </Grid>
</Window>
