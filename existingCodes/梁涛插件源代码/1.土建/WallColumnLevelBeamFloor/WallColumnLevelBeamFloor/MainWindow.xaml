<Window x:Class="WallColumnLevelBeamFloor.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WallColumnLevelBeamFloor"
             mc:Ignorable="d" 
              MinHeight="400" MaxHeight="600" MinWidth="200" MaxWidth="400" Height="400" Width="250" WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip" WindowStyle="None" AllowsTransparency="True" Background="#FFF0F0F0" BorderThickness="0.7" BorderBrush="Black">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" MouseMove="Grid_MouseMove" Background="White">
            <Label Content="墙柱齐梁板"/>
            <StackPanel Margin="0" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Width="30" Height="30" VerticalAlignment="Center" Cursor="Hand" ToolTip="关闭" MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave" Click="Button_Click_2" PreviewMouseDown="Button_PreviewMouseDown">
                    <Button.Template>
                        <ControlTemplate>
                            <Grid Background="Transparent">
                                <Line Width="10" Height="10" X1="0" Y1="0" X2="10" Y2="10" StrokeThickness="1" Stroke="Black" ></Line>
                                <Line Width="10" Height="10" X1="10" Y1="0" X2="0" Y2="10" StrokeThickness="1" Stroke="Black" ></Line>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
        <GroupBox Grid.Row="1" Margin="15,10,15,10" Header="构件选择">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.5*"/>
                    <ColumnDefinition Width="0.5*"/>
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" x:Name="cb_wall" Content="墙" IsChecked="True" HorizontalAlignment="Center" VerticalAlignment="Center" Click="CheckBox_Click"/>
                <CheckBox Grid.Column="1" x:Name="cb_column" Content="柱" IsChecked="True" HorizontalAlignment="Center" VerticalAlignment="Center" Click="CheckBox_Click"/>
            </Grid>
        </GroupBox>
        <TabControl Grid.Row="2" Margin="15">
            <TabItem Header="墙柱设置">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.5*"/>
                        <RowDefinition Height="0.5*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Margin="15,5,15,5" BorderThickness="0.7" BorderBrush="DimGray" CornerRadius="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.5*"/>
                                <RowDefinition Height="0.5*"/>
                            </Grid.RowDefinitions>
                            <RadioButton x:Name="rb_struct"  Grid.Row="0" Content="齐结构板" Margin="5" IsChecked="True" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <RadioButton x:Name="rb_build" Grid.Row="1" Content="齐建筑板" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.5*"/>
                            <ColumnDefinition Width="0.5*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Margin="15,5,10,5" BorderThickness="0.7" BorderBrush="DimGray" CornerRadius="5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="0.5*"/>
                                    <RowDefinition Height="0.5*"/>
                                </Grid.RowDefinitions>
                                <CheckBox x:Name="cb_upL"  Content="上齐" Grid.Row="0" IsChecked="True" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center" Click="CheckBox_Click"/>
                                <CheckBox x:Name="cb_downL"  Content="下齐" Grid.Row="1" IsChecked="True" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center" Click="CheckBox_Click"/>
                            </Grid>
                        </Border>
                        <Border Grid.Column="1" Margin="10,5,15,5" BorderThickness="0.7" BorderBrush="DimGray" CornerRadius="5">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="0.5*"/>
                                    <RowDefinition Height="0.5*"/>
                                </Grid.RowDefinitions>
                                <CheckBox x:Name="cb_levelB" Content="齐梁" Grid.Row="0" IsChecked="True" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center" Click="CheckBox_Click"/>
                                <CheckBox x:Name="cb_levelF" Content="齐板" Grid.Row="1" IsChecked="True" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center" Click="CheckBox_Click"/>
                            </Grid>  
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
        <Button IsDefault="True" Grid.Row="3" Margin="15,0,15,10" Width="70" Height="20" Content="确定" HorizontalAlignment="Left" VerticalAlignment="Center" Click="Button_Click"/>
        <Button IsCancel="True" Grid.Row="3" Margin="15,0,15,10" Width="70" Height="20" Content="取消" HorizontalAlignment="Right" VerticalAlignment="Center"/>

    </Grid>
</Window>
