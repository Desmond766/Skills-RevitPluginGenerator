<Window x:Class="BatchUnJoin.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BatchUnJoin"
             mc:Ignorable="d" Height="450" Title="批量取消连接" Width="250" MinWidth="250" MinHeight="450" WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.15*"/>
            <RowDefinition Height="0.6*"/>
            <RowDefinition Height="0.15*"/>
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>
        <GroupBox Grid.Row="0" Margin="10" Header="选择">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.5*"/>
                    <ColumnDefinition Width="0.5*"/>
                </Grid.ColumnDefinitions>
                <RadioButton Name="rb_category" IsChecked="True" GroupName="rb_sel" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="0" Content="按类型" Click="RadioButton_Click"/>
                <RadioButton GroupName="rb_sel" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="1" Content="手动框选" Click="RadioButton_Click"/>
            </Grid>
        </GroupBox>
        <ListBox Grid.Row="1" Name="list" Margin="10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid HorizontalAlignment="Stretch" Height="20" MinWidth="160">
                        <Label Width="auto" Height="30" Content="{Binding CategoryName, Mode=TwoWay}"/>
                        <Button Width="30" Content="{Binding ButtonName, Mode=TwoWay}" Foreground="Green" Background="Transparent" BorderThickness="0" Click="Button_Click" HorizontalAlignment="Right" Margin="0,0,-25,0"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <GroupBox Name="gb_scope" Header="修改范围" Grid.Row="2" Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.5*"/>
                    <ColumnDefinition Width="0.5*"/>
                </Grid.ColumnDefinitions>
                <RadioButton Name="rb_current_view" IsChecked="True" GroupName="rb_scope" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="0" Content="当前视图"/>
                <RadioButton GroupName="rb_scope" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="1" Content="项目"/>
            </Grid>
        </GroupBox>
        <Button Content="确定" Grid.Row="3" Width="60" Height="25" IsDefault="True" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,80,0" Click="Button_Click_1"/>
        <Button Content="取消" Grid.Row="3" Width="60" Height="25" IsCancel="True" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>

    </Grid>
</Window>
