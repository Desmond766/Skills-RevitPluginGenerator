<Window x:Class="ReviewParkingSpaceSpacing.ResultWPF"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReviewParkingSpaceSpacing"
             mc:Ignorable="d" Height="500" Width="300" WindowStartupLocation="CenterOwner" Topmost="True" Title="复核车位间距">
    <Window.Resources>
        <ResourceDictionary>
            <Style x:Key="dgCell" TargetType="TextBlock">
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="5"/>
            </Style>
            <Style x:Key="ColumnHeaderStyleC" TargetType="DataGridColumnHeader">
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="ToolTip" Value="Click to sort."/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <DataGrid ColumnWidth="*" CanUserAddRows="False" CanUserDeleteRows="False" AutoGenerateColumns="False" x:Name="list" ColumnHeaderStyle="{DynamicResource ColumnHeaderStyleC}" SelectionChanged="list_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Width="0.5*" x:Name="elem_type" Header="名称" Binding="{Binding Name}" IsReadOnly="True" ElementStyle="{StaticResource dgCell}"/>
                <DataGridTextColumn Width="0.5*" x:Name="elem_name" Header="ID" Binding="{Binding Id}" IsReadOnly="True" ElementStyle="{StaticResource dgCell}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
