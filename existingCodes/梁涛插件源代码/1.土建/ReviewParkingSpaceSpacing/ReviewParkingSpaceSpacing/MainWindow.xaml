<Window x:Class="ReviewParkingSpaceSpacing.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReviewParkingSpaceSpacing"
             mc:Ignorable="d" Height="180" Width="220"  WindowStartupLocation="CenterOwner" Topmost="True">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.5*"/>
            <ColumnDefinition Width="0.5*"/>
        </Grid.ColumnDefinitions>
        <Label Content="墙柱模型所在位置" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,80" Grid.ColumnSpan="2"/>
        <Button Grid.Column="0" Content="当前模型" HorizontalAlignment="Center" Margin="0,50,0,0" VerticalAlignment="Center" Width="60" Height="25" Click="Button_Click"/>
        <Button Grid.Column="1" Content="链接模型" HorizontalAlignment="Center" Margin="0,50,0,0" VerticalAlignment="Center" Width="60" Height="25" Click="Button_Click_1"/>

    </Grid>
</Window>
