<Window x:Class="ReviewDoorClearHeight.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReviewDoorClearHeight"
             mc:Ignorable="d" Height="350" Width="230" WindowStartupLocation="CenterOwner" Topmost="True" Title="复核人防门净高">
    <Window.Resources>
        <ResourceDictionary>
            <Style x:Key="dgCell" TargetType="TextBlock">
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="5"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="ToolTip" Value="点击跳转"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="ColumnHeaderStyleC" TargetType="DataGridColumnHeader">
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="ToolTip" Value="Click to sort."/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <DataGrid ColumnWidth="*" MinHeight="50" MinWidth="20" Name="list" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" ColumnHeaderStyle="{DynamicResource ColumnHeaderStyleC}" SelectionChanged="list_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="安装范围净高" IsReadOnly="True" Width="0.3*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Label HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderThickness="0"
                                            Content="{Binding InstallClearHeightInScope}" Foreground="{Binding InstallFontColor}"
                                            Background="{Binding InstallColor}" BorderBrush="#FF44362E" FontWeight="{Binding InstallFontWeight}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="开启范围净高" IsReadOnly="True" Width="0.3*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Label HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderThickness="0"
                                            Content="{Binding OpenClearHeightInScope}" Foreground="{Binding OpenFontColor}"
                                            Background="{Binding OpenColor}" BorderBrush="#FF44362E" FontWeight="{Binding OpenFontWeight}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Visibility="Collapsed" Header="安装范围净高" Binding="{Binding InstallClearHeightInScope}" IsReadOnly="True" Width="0.3*" ElementStyle="{StaticResource dgCell}"/>
                <DataGridTextColumn Visibility="Collapsed" Header="开启范围净高" Binding="{Binding OpenClearHeightInScope}" IsReadOnly="True" Width="0.3*" ElementStyle="{StaticResource dgCell}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
