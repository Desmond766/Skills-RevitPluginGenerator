<Window x:Class="ReviewDoorClearHeight.SelWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReviewDoorClearHeight"
             mc:Ignorable="d" Height="200" Width="550" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="0,0,0,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.5*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.9*"/>
            <ColumnDefinition Width="100"/>
        </Grid.ColumnDefinitions>
        <GroupBox Header="梁板所在模型" Margin="5,5,5,5" Grid.Column="0" Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.3*"/>
                    <ColumnDefinition Width="0.3*"/>
                    <ColumnDefinition Width="0.3*"/>
                </Grid.ColumnDefinitions>
                <RadioButton IsChecked="True" Name="rb_link" Content="链接模型" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="0"/>
                <RadioButton Name="rb_local" Content="本地模型" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1"/>
                <RadioButton Name="rb_both" Content="同时存在" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="2"/>
            </Grid>
        </GroupBox>
        <GroupBox Header="门所在模型" Margin="5,5,5,5" Grid.Column="0" Grid.Row="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.5*"/>
                    <ColumnDefinition Width="0.5*"/>
                </Grid.ColumnDefinitions>
                <RadioButton x:Name="rb_link_door" IsChecked="True" Content="链接模型" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="0"/>
                <RadioButton x:Name="rb_local_door" Content="本地模型" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1"/>
            </Grid>
        </GroupBox>
        <Grid Grid.Column="1" Margin="5,10,5,0" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.5*"/>
                <RowDefinition Height="0.5*"/>
            </Grid.RowDefinitions>
            <Button Grid.Row="0" Content="确定" HorizontalAlignment="Center" VerticalAlignment="Center" Width="60" Height="25" IsDefault="True" Click="Button_Click"/>
            <Button Grid.Row="1" Content="取消" HorizontalAlignment="Center" VerticalAlignment="Center" Width="60" Height="25" IsCancel="True"/>
        </Grid>
    </Grid>
</Window>
