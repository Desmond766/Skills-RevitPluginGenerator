<Window x:Class="RampArrowParallelFloor.PreviewWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RampArrowParallelFloor"
             mc:Ignorable="d" Height="400" Width="600" WindowStartupLocation="CenterScreen" Topmost="True" ResizeMode="NoResize" Title="坡道箭头布置预览窗口">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="0.2*"/>
        </Grid.RowDefinitions>
        <Grid Name="grid_preview" Grid.Row="0">

        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.3*"/>
                <ColumnDefinition Width="0.7*"/>
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="chb_opposite" Grid.Column="0" Content="坡道箭头反向布置" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Button Grid.Column="1" IsDefault="True" Height="30" Width="70" Content="确定" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,0" Click="Button_Click"/>
            <Button Grid.Column="1" IsCancel="True" Height="30" Width="70" Content="取消" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="200,0,0,0"/>

        </Grid>

    </Grid>
</Window>
