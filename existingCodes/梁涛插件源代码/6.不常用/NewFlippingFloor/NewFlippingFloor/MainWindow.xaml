<Window x:Class="NewFlippingFloor.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NewFlippingFloor"
             mc:Ignorable="d" WindowStartupLocation="CenterScreen" Height="231" Width="350">
    <Grid>
        <Label Content="标高:" HorizontalAlignment="Left" Margin="52,20,0,0" VerticalAlignment="Top"/>
        <Label Content="类型:" HorizontalAlignment="Left" Margin="52,91,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cb_level" HorizontalAlignment="Left" Margin="113,22,0,0" VerticalAlignment="Top" Width="157" SelectedIndex="0" HorizontalContentAlignment="Center">
            <ComboBoxItem Content="默认"/>
        </ComboBox>
        <ComboBox x:Name="cb_high" HorizontalAlignment="Left" Margin="113,93,0,0" VerticalAlignment="Top" Width="157" SelectedIndex="0" HorizontalContentAlignment="Center">
            <ComboBoxItem Content="默认"/>
        </ComboBox>
        <Button Content="确定" HorizontalAlignment="Left" Margin="194,155,0,0" VerticalAlignment="Top" Width="32" Click="Button_Click"/>
        <Button Content="取消" HorizontalAlignment="Left" Margin="237,155,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.515,0.559" Width="33" Click="Button_Click_1"/>
        <Label Content="自标高的高度偏移:" HorizontalAlignment="Left" Margin="0,56,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tb_level_offset" HorizontalAlignment="Left" Margin="113,60,0,0" TextWrapping="Wrap" Text="0" VerticalAlignment="Top" Width="157"/>
        <Label Content="mm" HorizontalAlignment="Left" Margin="275,56,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
