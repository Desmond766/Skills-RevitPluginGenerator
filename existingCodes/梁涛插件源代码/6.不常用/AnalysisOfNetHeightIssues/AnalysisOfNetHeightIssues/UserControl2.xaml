<Window x:Class="AnalysisOfNetHeightIssues.UserControl2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnalysisOfNetHeightIssues"
             mc:Ignorable="d" Height="440" Width="525" WindowStartupLocation="CenterScreen" Topmost="True">
    <Grid>
        <DataGrid Name="list" AutoGenerateColumns="False" SelectionChanged="list_SelectionChanged" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="差值(mm)" Binding="{Binding spacing}" IsReadOnly="True"/>
                <DataGridTextColumn Header="输入值(mm)" Binding="{Binding inputValue}" IsReadOnly="True"/>
                <DataGridTextColumn Header="结果" Binding="{Binding result}" IsReadOnly="True"/>
                <DataGridTextColumn Header="梁ID" Binding="{Binding beamId}" IsReadOnly="True"/>
                <DataGridTextColumn Header="风管ID" Binding="{Binding ductId}" IsReadOnly="True"/>
                <DataGridTextColumn Header="备注" Binding="{Binding notes}"/>
                <!-- Add more columns as needed -->
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
