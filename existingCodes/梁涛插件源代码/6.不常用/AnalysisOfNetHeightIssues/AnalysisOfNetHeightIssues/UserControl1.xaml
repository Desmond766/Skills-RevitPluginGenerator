<Window x:Class="AnalysisOfNetHeightIssues.UserControl1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnalysisOfNetHeightIssues"
             mc:Ignorable="d" WindowStartupLocation="CenterScreen" Height="203" Width="322">
    <Grid>
        <Label Content="净高检测:" HorizontalAlignment="Left" Margin="15,19,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tb" HorizontalAlignment="Left" Margin="81,23,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <Label Content="mm" HorizontalAlignment="Left" Margin="209,19,0,0" VerticalAlignment="Top"/>
        <Button Content="确定" HorizontalAlignment="Left" Margin="203,110,0,0" VerticalAlignment="Top" Click="Button_Click"/>
        <RadioButton Content="完整模型" HorizontalAlignment="Left" Margin="0,75,0,0" VerticalAlignment="Top" IsChecked="True"/>
        <RadioButton x:Name="cs"  Content="初始模型" HorizontalAlignment="Left" Margin="0,51,0,0" VerticalAlignment="Top" Checked="cs_Checked"/>
        <TextBox x:Name="floorHeight" HorizontalAlignment="Left" Margin="81,49,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" TextChanged="height_TextChanged" IsEnabled="False">
            
        </TextBox>
        <Label Content="mm" HorizontalAlignment="Left" Margin="209,45,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
