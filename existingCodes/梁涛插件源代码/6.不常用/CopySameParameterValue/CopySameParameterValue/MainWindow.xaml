<Window x:Class="CopySameParameterValue.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CopySameParameterValue"
             mc:Ignorable="d" Height="383" Width="432" Topmost="True" WindowStartupLocation="CenterScreen" Title="参数复制">
    <Grid>
        <Label Content="类别: " VerticalContentAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="50,-160,0,0"/>
        <ComboBox Name="cb_cate" VerticalContentAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="120,-160,0,0" Width="200" Height="30" SelectionChanged="cb_cate_SelectionChanged">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="{Binding CategoryName}" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <Label Content="参数源: " VerticalContentAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="50,-40,0,0"/>
        <ComboBox Name="cb_source" VerticalContentAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="120,-40,0,0" Width="200" Height="30">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="{Binding ParaName}" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <Label Content="目标参数: " VerticalContentAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="50,80,0,0"/>
        <ComboBox Name="cb_target" VerticalContentAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="120,80,0,0" Width="200" Height="30">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" IsEnabled="{Binding IsEnabled}">
                        <Label Content="{Binding ParaName}" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <Button Content="确定" IsDefault="True" HorizontalAlignment="Left" Margin="100,270,0,0" VerticalAlignment="Top" Width="60" Height="25" Click="Button_Click"/>
        <Button Content="取消" IsCancel="True" HorizontalAlignment="Left" Margin="250,270,0,0" VerticalAlignment="Top" Width="60" Height="25"/>
    </Grid>
</Window>
