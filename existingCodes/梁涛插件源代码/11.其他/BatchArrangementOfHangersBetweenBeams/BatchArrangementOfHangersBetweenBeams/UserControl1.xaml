<Window x:Class="BatchArrangementOfHangersBetweenBeams.UserControl1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BatchArrangementOfHangersBetweenBeams"
             mc:Ignorable="d" WindowStartupLocation="CenterScreen" Height="425" Width="698" Title="梁间布置支吊架">
    <Grid>
        <Label Content="族" HorizontalAlignment="Left" Margin="88,78,0,0" VerticalAlignment="Top" Height="49" Width="115" FontSize="20" FontWeight="Bold"/>
        <Label Content="族类型" HorizontalAlignment="Left" Margin="64,129,0,0" VerticalAlignment="Top" Height="51" Width="129" FontSize="20" FontWeight="Bold"/>
        <ComboBox x:Name="comboBox" HorizontalAlignment="Left" Margin="266,139,0,0" VerticalAlignment="Top" Width="223" FontSize="20" SelectedIndex="0" SelectionChanged="comboBox_SelectionChanged"/>
        <Button Content="确定" HorizontalAlignment="Left" Margin="266,237,0,0" VerticalAlignment="Top" FontSize="20" Width="75" FontWeight="Bold" Click="Button_Click_1"/>
        <Button Content="取消" HorizontalAlignment="Left" Margin="373,238,0,0" VerticalAlignment="Top" FontSize="20" Width="75" FontWeight="Bold" Click="Button_Click"/>
        <CheckBox x:Name="uprightPole" Content="中间立杆" HorizontalAlignment="Left" Margin="472,244,0,0" VerticalAlignment="Top" FontWeight="Bold" IsChecked="True" Height="15" Width="95" >
            <CheckBox.LayoutTransform>
                <ScaleTransform ScaleX="1.5" ScaleY="1.5" />
            </CheckBox.LayoutTransform>
        </CheckBox>
        <RadioButton x:Name="singleLayer" Content="单层" HorizontalAlignment="Left" Margin="75,187,0,0" VerticalAlignment="Top" FontWeight="Bold" IsChecked="True" GroupName="hangerType">
            <RadioButton.LayoutTransform>
                <ScaleTransform ScaleX="1.5" ScaleY="1.5"></ScaleTransform>
            </RadioButton.LayoutTransform>
        </RadioButton>
        <RadioButton x:Name="bilayer" Content="双层" HorizontalAlignment="Left" Margin="75,245,0,0" VerticalAlignment="Top" Checked="RadioButton_Checked" FontWeight="Bold" GroupName="hangerType">
            <RadioButton.LayoutTransform>
                <ScaleTransform ScaleX="1.5" ScaleY="1.5"></ScaleTransform>
            </RadioButton.LayoutTransform>
        </RadioButton>
        <ComboBox x:Name="comboBox2" HorizontalAlignment="Left" Margin="266,80,0,0" VerticalAlignment="Top" Width="223" Height="32" FontSize="20" SelectedIndex="0" SelectionChanged="comboBox2_SelectionChanged"/>
        <CheckBox x:Name="check" Content="不在梁间布置" HorizontalAlignment="Left" Margin="188,328,0,0" VerticalAlignment="Top" Checked="CheckBox_Checked"/>
        <Label x:Name="lb" Content="吊架间距" HorizontalAlignment="Left" Margin="310,322,0,0" VerticalAlignment="Top" Visibility="Hidden"/>
        <TextBox x:Name="tb" HorizontalAlignment="Left" Margin="373,326,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" TextChanged="TextBox_TextChanged" Visibility="Hidden"/>
    </Grid>
</Window>
