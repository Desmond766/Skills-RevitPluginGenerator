<Window x:Class="ClosedFloorLine.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClosedFloorLine"
             mc:Ignorable="d" Height="90" Width="350" WindowStartupLocation="CenterScreen" Topmost="True">
    <Grid>
        <Label Content="模型线两端延长长度：" VerticalAlignment="Center"/>
        <TextBox x:Name="tb_length" Text="100" VerticalContentAlignment="Center" Height="20" Width="60" HorizontalAlignment="Left" Margin="120,0,0,0"/>
        <Label Content="mm" VerticalAlignment="Center" Margin="180,0,0,0"/>
        <Button Content="确定" IsDefault="True" Height="20" Width="40" Margin="220,0,0,0" HorizontalAlignment="Left" Click="Button_Click"/>
        <Button Content="取消" IsCancel="True" Height="20" Width="40" Margin="270,0,0,0" HorizontalAlignment="Left" Click="Button_Click_1"/>
    </Grid>
</Window>
