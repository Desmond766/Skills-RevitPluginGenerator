<Window x:Class="HangerQuantity.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HangerQuantity"
             mc:Ignorable="d" Height="156" Width="181" WindowStartupLocation="CenterScreen">
    <Grid>
        <CheckBox x:Name="cb_water" Margin="15,20,0,0" Content="水电抗震吊架出图" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <CheckBox x:Name="cb_hvac" Margin="15,40,0,0" Content="暖通抗震吊架出图" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Button Content="确定" IsDefault="True" HorizontalAlignment="Left" Margin="80,80,0,0" VerticalAlignment="Top" Click="Button_Click"/>
        <Button Content="取消" IsCancel="True" HorizontalAlignment="Left" Margin="120,80,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
