<Window x:Class="FindBrokenCableTrays.ShowWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FindBrokenCableTrays"
             mc:Ignorable="d" Height="464" Width="223" Topmost="True" WindowStartupLocation="CenterScreen">
    <Grid>
        <DataGrid CanUserAddRows="False" AutoGenerateColumns="False" CanUserDeleteRows="False" x:Name="list" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" SelectionChanged="list_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="桥架名称" Binding="{Binding CableTrayName}"></DataGridTextColumn>
                <DataGridTextColumn Header="桥架ID" Binding="{Binding CableTrayId}"></DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Window>
