<Window x:Class="FillRoute.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FillRoute"
             mc:Ignorable="d" Height="392" Width="500" Title="路由填充" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.3*"/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="0.15*"/>
        </Grid.RowDefinitions>
        <GroupBox Grid.Row="0" Height="60" Header="路由列表选择" Margin="10">
            <StackPanel Orientation="Horizontal">
                <Label VerticalAlignment="Center" Content="文件路径:" Margin="5"/>
                <TextBox Height="20" VerticalContentAlignment="Center" Width="300" VerticalAlignment="Center" Margin="5" Name="tb_file_route" />
                <Button VerticalContentAlignment="Center" VerticalAlignment="Center" Height="20" Width="60" Margin="5" Content="选择" Click="Button_Click"/>
            </StackPanel>
        </GroupBox>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>
            <GroupBox Grid.Column="0" Margin="10" Header="所有路由">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.2*"/>
                        <RowDefinition Height="0.8*"/>
                    </Grid.RowDefinitions>
                    <ComboBox IsEditable="True" Name="cb_start_route" Grid.Row="0" Height="20" Width="130" VerticalContentAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0" SelectionChanged="cb_start_route_SelectionChanged" Visibility="Collapsed"/>
                    <TextBox x:Name="tb_search" Grid.Row="0" Height="20" Width="130" VerticalContentAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0" SelectionChanged="TextBox_SelectionChanged" />
                    <Button Content="重置" Height="20" Width="60" VerticalContentAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0" Grid.Row="0" Click="Button_Click_1"/>
                    <ListBox Grid.Row="1" Margin="5" Name="list_all_route">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Stretch" Height="20" MinWidth="160">
                                    <Label Width="auto" Height="30" Content="{Binding RouteName, Mode=TwoWay}" Margin="10,0,0,0" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Left"/>
                                    <Button Width="30" Content="{Binding RouteState, Mode=TwoWay}" Margin="0,0,-10,0"  Foreground="Green" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Right" Click="Button_Click_3"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Column="1" Margin="10" Header="本次填充路由">
                <ListBox Margin="5" Name="list_add_route">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="20" HorizontalAlignment="Stretch" MinWidth="160" Width="{Binding Width, ElementName = list_add_route, Mode=OneWay}">
                                <Label Width="auto" Height="30" Content="{Binding RouteName, Mode=TwoWay}" Margin="10,0,0,0" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Left"/>
                                <Button Width="30" Content="-" Margin="0,0,-10,0"  Foreground="Red" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Right" Click="Button_Click_4"/>
                            </Grid>

                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </Grid>

        <Grid Grid.Row="2">
            <Button IsDefault="True" Content="确定" Width="60" Height="20" VerticalAlignment="Center" VerticalContentAlignment="Center" Margin="200,0,0,0" Click="Button_Click_2"/>
            <Button IsCancel="True" Content="取消" Width="60" Height="20" VerticalAlignment="Center" VerticalContentAlignment="Center" Margin="370,0,0,0"/>
        </Grid>

    </Grid>
</Window>
