<Window x:Class="FindLightPath.LightRouteWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FindLightPath"
             mc:Ignorable="d" Height="585" Width="310" WindowStartupLocation="CenterScreen" Topmost="True">
    <Window.Resources>
        <ResourceDictionary>
            <Style x:Key="dgCell" TargetType="TextBlock">
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="ColumnHeaderStyleC" TargetType="DataGridColumnHeader">
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="ToolTip" Value="点击排序"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <DataGrid Grid.Row="0" x:Name="list" ColumnHeaderStyle="{DynamicResource ColumnHeaderStyleC}"  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" ItemsSource="{Binding}" SelectionChanged="list_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding PowerLightId, Mode=TwoWay}" ElementStyle="{StaticResource dgCell}" Header="通电灯具节点"/>
                <DataGridTextColumn Binding="{Binding Length, Mode=TwoWay}" ElementStyle="{StaticResource dgCell}" Header="长度(M)"/>
                <DataGridTextColumn Binding="{Binding UnPowerLightId, Mode=TwoWay}" ElementStyle="{StaticResource dgCell}" Header="未通电灯具节点"/>
                <DataGridTextColumn Binding="{Binding IsConnect, Mode=TwoWay}" ElementStyle="{StaticResource dgCell}" Header="是否连接"/>
            </DataGrid.Columns>
        </DataGrid>
        <Grid Grid.Row="1">
            <Label Content="总长度：" HorizontalAlignment="Left" Margin="28,27,0,0" VerticalAlignment="Top"/>
            <Label Name="lb_length" Content="000M" HorizontalAlignment="Left" Margin="91,27,0,0" VerticalAlignment="Top"/>
            <Label Content="灯具编号：" HorizontalAlignment="Left" Margin="28,0,0,0" VerticalAlignment="Top"/>
            <Label Content="ABC"  Name="lb_light_num" HorizontalAlignment="Left" Margin="103,0,0,0" VerticalAlignment="Top"/>
            <Label Content="回路编号：" HorizontalAlignment="Left" Margin="28,52,0,0" VerticalAlignment="Top"/>
            <Label Name="lb_route_num" Content="??:??" HorizontalAlignment="Left" Margin="103,52,0,0" VerticalAlignment="Top"/>
        </Grid>
        <Button Content="选中赋值" HorizontalAlignment="Left" Margin="28,0,0,0" Grid.Row="2" VerticalAlignment="Center" Width="60" Height="20" Click="Button_Click"/>
        <Button Content="一键赋值" HorizontalAlignment="Left" Margin="120,0,0,0" Grid.Row="2" VerticalAlignment="Center" Width="60" Height="20" Click="Button_Click_1"/>
    </Grid>
</Window>
