<Window x:Class="FindLightPath.SelWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FindLightPath"
             mc:Ignorable="d" Height="182" Width="454" WindowStartupLocation="CenterScreen" Topmost="True">
    <Grid>
        <Label Content="设置循环次数" HorizontalAlignment="Left" Margin="27,30,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tb_run_num" HorizontalAlignment="Left" Margin="114,34,0,0" TextWrapping="Wrap" Text="100000" VerticalAlignment="Top" Width="120"/>
        <Label Content="次" HorizontalAlignment="Left" Margin="239,30,0,0" VerticalAlignment="Top"/>
        <Label Content="选择灯具编号" HorizontalAlignment="Left" Margin="27,78,0,0" VerticalAlignment="Top"/>
        <ComboBox Name="cb_light_num" HorizontalAlignment="Left" Margin="114,80,0,0" VerticalAlignment="Top" Width="120"/>
        <Button IsDefault="True" Content="确定" Width="50" Height="20" HorizontalAlignment="Left" Margin="291,81,0,0" VerticalAlignment="Top" Click="Button_Click"/>
        <Button IsCancel="True" Content="取消" Width="50" Height="20" HorizontalAlignment="Left" Margin="347,81,0,0" VerticalAlignment="Top"/>
        <Label Content="(设置次数越多运行时间越长)" Foreground="OrangeRed" HorizontalAlignment="Left" Margin="266,30,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
