<Window x:Class="CreateTextForBothEndsOfPipeline.SelWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CreateTextForBothEndsOfPipeline"
             mc:Ignorable="d" WindowStartupLocation="CenterScreen" Height="200" Width="400" Title="注释内容设置（按回车键以确定选择）">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.25*"/>
            <RowDefinition Height="0.25*"/>
            <RowDefinition Height="0.25*"/>
            <RowDefinition Height="0.25*"/>
        </Grid.RowDefinitions>
        <RadioButton x:Name="rb_round" Content="取整" IsChecked="True" GroupName="sel" Grid.Row="0" Margin="10" VerticalAlignment="Center"/>
        <RadioButton x:Name="rb_save"  Content="保留小数点后两位" GroupName="sel" Grid.Row="1" Margin="10" VerticalAlignment="Center"/>
        <Button Content="       确定(Enter键)" Grid.Row="2" HorizontalContentAlignment="Left" Margin="0,0,0,0" Background="{x:Null}" Click="Button_Click" IsDefault="True"/>
        <Button Content="       取消(Esc键)" Grid.Row="3" HorizontalContentAlignment="Left" Margin="0,0,0,0" Background="{x:Null}" Click="Button_Click_1" IsCancel="True"/>
    </Grid>
</Window>
