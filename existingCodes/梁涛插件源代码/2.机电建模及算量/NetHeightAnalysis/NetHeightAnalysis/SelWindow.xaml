<Window x:Class="NetHeightAnalysis.SelWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NetHeightAnalysis"
             mc:Ignorable="d" Height="500" Width="470" WindowStartupLocation="CenterOwner" Title="净高分析">
    <Window.Resources>
        <ResourceDictionary>
            <Style x:Key="dgCell" TargetType="TextBlock">
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="5"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="ToolTip" Value="按Del键删除选中行"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="ColumnHeaderStyleC" TargetType="DataGridColumnHeader">
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="ToolTip" Value="Click to sort."/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.2*"/>
            <RowDefinition Height="0.6*"/>
            <RowDefinition Height="0.2*"/>
        </Grid.RowDefinitions>
        <GroupBox Header="文字注释选择" Margin="5" Grid.Row="0">
            <Grid>
                <ComboBox x:Name="cb_text_type" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Height="30" Margin="20,0"/>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="1" Header="自定义填充范围" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Margin="0,2" BorderBrush="DarkGray" BorderThickness="0.7" CornerRadius="0.5">
                    <Grid>
                        <TextBox VerticalContentAlignment="Center" Width="60" Height="24" Name="tb_min" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0"/>
                        <Label Content="mm &lt;= 净高 &lt;" Width="100" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="65,0,0,0"/>
                        <TextBox VerticalContentAlignment="Center" Width="60" Height="24" Name="tb_max" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="160,0,0,0"/>
                        <Label Content="mm" Width="60" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="220,0,0,0"/>
                        <ComboBox Name="cb_fill_type" Width="90" Height="25" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="260,0,0,0" VerticalContentAlignment="Center"/>
                        <Button Content="添加" Width="60" Height="25" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="360,0,0,0" Click="Button_Click_2"/>
                    </Grid>
                </Border>
                <DataGrid Grid.Row="1" ColumnWidth="*" MinHeight="50" MinWidth="20" Name="list" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="True" ColumnHeaderStyle="{DynamicResource ColumnHeaderStyleC}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="最小值(mm)" Binding="{Binding Min}" IsReadOnly="True" Width="0.3*" ElementStyle="{StaticResource dgCell}"/>
                        <DataGridTextColumn Header="最大值(mm)" Binding="{Binding Max}" IsReadOnly="True" Width="0.3*" ElementStyle="{StaticResource dgCell}"/>
                        <DataGridTextColumn Header="区域填充类型" Binding="{Binding FilledRegionTypeName}" IsReadOnly="True" Width="0.3*" ElementStyle="{StaticResource dgCell}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>
        <Button Grid.Row="2" Height="30" Width="60" Content="确定" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,110,0" IsDefault="True" Click="Button_Click"/>
        <Button Grid.Row="2" Height="30" Width="60" Content="取消" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,30,0" IsCancel="True" Click="Button_Click_1"/>

    </Grid>
</Window>
