<Window x:Class="NetHeightAnalysis.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NetHeightAnalysis"
             mc:Ignorable="d"  Width="250" Height="450" Topmost="True" WindowStartupLocation="CenterScreen" Title="净高分析复核" ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <ResourceDictionary>
            <Style x:Key="dgCell" TargetType="TextBlock">
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="5"/>
            </Style>
            <Style x:Key="ColumnHeaderStyleC" TargetType="DataGridColumnHeader">
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="ToolTip" Value="Click to sort."/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.9*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <DataGrid Grid.Row="0" ColumnWidth="*" MinHeight="50" MinWidth="20" Name="list" AutoGenerateColumns="False" CanUserAddRows="False" ColumnHeaderStyle="{DynamicResource ColumnHeaderStyleC}" Grid.RowSpan="2" SelectionChanged="list_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="元素ID" Binding="{Binding ElementId}" IsReadOnly="True" Width="0.3*" ElementStyle="{StaticResource dgCell}" Visibility="Collapsed"/>
                <DataGridTemplateColumn Header="填充颜色" IsReadOnly="True" Width="0.3*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{Binding Color}" BorderThickness="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="元素类型" Binding="{Binding ElementType}" IsReadOnly="True" Width="0.3*" ElementStyle="{StaticResource dgCell}"/>
                <DataGridTextColumn Header="净高(mm)" Binding="{Binding ClearHeight}" IsReadOnly="True" Width="0.3*" ElementStyle="{StaticResource dgCell}"/>
            </DataGrid.Columns>
        </DataGrid>
        <Button Content="创建净高对应色块" Grid.Row="1" Click="Button_Click" Visibility="Collapsed"/>
    </Grid>
</Window>
