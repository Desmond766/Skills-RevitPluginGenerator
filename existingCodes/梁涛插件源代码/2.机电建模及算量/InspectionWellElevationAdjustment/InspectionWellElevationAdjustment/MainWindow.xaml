<Window x:Class="InspectionWellElevationAdjustment.MainWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InspectionWellElevationAdjustment"
             mc:Ignorable="d" Height="500" Width="500" WindowStartupLocation="CenterOwner" Title="检查井标高调整">
    <Window.Resources>
        <ResourceDictionary>
            <Style x:Key="dgCell" TargetType="TextBlock">
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="5"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="ToolTip" Value="按Del键删除选中行"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="ColumnHeaderStyleC" TargetType="DataGridColumnHeader">
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="ToolTip" Value="Click to sort."/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.2*"/>
            <RowDefinition Height="0.6*"/>
            <RowDefinition Height="0.2*"/>
        </Grid.RowDefinitions>
        <GroupBox Header="检查井范围" Margin="5" Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.3*" />
                    <ColumnDefinition Width="0.3*" />
                    <ColumnDefinition Width="0.3*" />
                </Grid.ColumnDefinitions>
                <RadioButton x:Name="rb_sel" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="0" Content="框选检查井" IsChecked="True"/>
                <RadioButton x:Name="rb_current_view" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1" Content="当前视图可见"/>
                <RadioButton x:Name="rb_current_project"  HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="2" Content="当前项目"/>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="1" Header="自定义对应检测类型" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Margin="0,2" BorderBrush="DarkGray" BorderThickness="0.7" CornerRadius="0.5">
                    <Grid>
                        <Label Content="井类型:" Width="100" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0"/>
                        <ComboBox Name="cb_well_type" Width="90" Height="25" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="60,0,0,0" VerticalContentAlignment="Center"/>
                        <Label Content="对应管道类型:" Width="100" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="150,0,0,0"/>
                        <Button Width="60" Height="25" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="240,0,0,0" Content="选择" Click="Button_Click"/>
                        <Button Content="添加" Width="60" Height="25" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="360,0,0,0" Click="Button_Click_1"/>
                    </Grid>
                </Border>
                <DataGrid Grid.Row="1" ColumnWidth="*" MinHeight="50" MinWidth="20" Name="list" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="True" ColumnHeaderStyle="{DynamicResource ColumnHeaderStyleC}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="井类型名称" Binding="{Binding WellTypeName}" IsReadOnly="True" Width="0.3*" ElementStyle="{StaticResource dgCell}"/>
                        <DataGridTextColumn Header="管道类型名称" Binding="{Binding PipeTypeNames}" IsReadOnly="True" Width="0.3*" ElementStyle="{StaticResource dgCell}"/>
                        <DataGridTextColumn Header="区域填充类型" Binding="{Binding FilledRegionTypeName}" IsReadOnly="True" Width="0.3*" ElementStyle="{StaticResource dgCell}" Visibility="Collapsed"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>
        <Button Grid.Row="2" Height="30" Width="60" Content="确定" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,110,0" IsDefault="True" Click="Button_Click_2"/>
        <Button Grid.Row="2" Height="30" Width="60" Content="取消" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,30,0" IsCancel="True"/>
    </Grid>
</Window>
