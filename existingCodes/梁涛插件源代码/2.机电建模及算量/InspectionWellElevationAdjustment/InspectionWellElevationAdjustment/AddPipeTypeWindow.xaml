<Window x:Class="InspectionWellElevationAdjustment.AddPipeTypeWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InspectionWellElevationAdjustment"
             mc:Ignorable="d" Height="400" Width="280" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Title="选择管道类型">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.9*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <ListBox x:Name="list" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Grid.Row="0" SelectionMode="Extended"/>
        <Button Content="确定" Grid.Row="1" IsDefault="True" HorizontalAlignment="Right" VerticalAlignment="Center" Width="60" Height="25" Margin="0,0,80,0" Click="Button_Click_1"/>
        <Button Content="取消" Grid.Row="1" IsCancel="True" HorizontalAlignment="Right" VerticalAlignment="Center" Width="60" Height="25" Margin="0,0,10,0" Click="Button_Click"/>
    </Grid>
</Window>
