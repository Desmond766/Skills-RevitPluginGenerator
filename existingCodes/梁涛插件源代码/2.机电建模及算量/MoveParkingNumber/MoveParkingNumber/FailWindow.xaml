<Window x:Class="MoveParkingNumber.FailWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MoveParkingNumber"
             mc:Ignorable="d" Height="450" Width="300" WindowStartupLocation="CenterScreen" Topmost="True" Title="未调整车位号列表">
    <Grid>
        <DataGrid Grid.Row="1" CanUserAddRows="False" AutoGenerateColumns="False" CanUserDeleteRows="False" x:Name="list" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Grid.RowSpan="2" SelectionChanged="list_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn IsReadOnly="True" Header="车位号ID" Binding="{Binding}"></DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
