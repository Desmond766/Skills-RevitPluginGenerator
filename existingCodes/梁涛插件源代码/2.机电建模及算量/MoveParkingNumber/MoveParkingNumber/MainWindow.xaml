        <TextBox HorizontalAlignment="Left" Name="tb_max_angle" Margin="182,79,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <Label Content="mm" HorizontalAlignment="Left" Margin="337,37,0,0" VerticalAlignment="Top"/>
        <Label Content="度" HorizontalAlignment="Left" Margin="347,75,0,0" VerticalAlignment="Top"/>
        <Button Content="确定" IsDefault="True" Width="60" HorizontalAlignment="Left" Margin="316,147,0,0" VerticalAlignment="Top" Click="Button_Click"/>
        <Button Content="取消" IsCancel="True" Width="60" HorizontalAlignment="Left" Margin="394,147,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
