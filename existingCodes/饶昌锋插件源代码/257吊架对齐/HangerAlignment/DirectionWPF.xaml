<Window x:Class="HangerAlignment.DirectionWPF"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HangerAlignment"
             mc:Ignorable="d" Height="300" Width="450" Topmost="True" WindowStartupLocation="CenterScreen" Title="选择吊架当前方向">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.5*"/>
            <ColumnDefinition Width="0.5*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.7*"/>
            <RowDefinition Height="0.3*"/>
        </Grid.RowDefinitions>
        <TabControl Width="400" Height="150" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.ColumnSpan="2" Margin="25,0,0,0">
            <TabItem Header="吊架当前方向">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.5*"/>
                        <ColumnDefinition Width="0.5*"/>
                    </Grid.ColumnDefinitions>
                    <RadioButton Name="rb_px" IsChecked="True" Content="平行于X轴" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <RadioButton Name="rb_py" Content="平行于Y轴" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </TabItem>
        </TabControl>
        <CheckBox Content="本次运行不再弹出" Name="chb_tip" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="True"/>
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>
            <Button Content="确定" Grid.Column="0" Height="25" Width="60" HorizontalAlignment="Center" VerticalAlignment="Center" IsDefault="True" Click="Button_Click"/>
            <Button Content="取消" Grid.Column="1" Height="25" Width="60" HorizontalAlignment="Center" VerticalAlignment="Center" Click="Button_Click_1"/>

        </Grid>

    </Grid>
</Window>
