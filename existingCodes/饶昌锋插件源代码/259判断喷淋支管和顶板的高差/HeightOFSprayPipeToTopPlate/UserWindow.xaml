        <Label Content="参数：" HorizontalAlignment="Left" Margin="52,72,0,0" VerticalAlignment="Top" Height="35" Width="60" FontSize="20"/>
        <TextBox x:Name="HeightDifference" HorizontalAlignment="Left" Margin="117,74,0,0" TextWrapping="Wrap" Text="0" VerticalAlignment="Top" Width="132" Height="35" FontSize="24" KeyUp="Window_KeyUp"/>
        <CheckBox x:Name="cb_pipe" Content="喷淋支管" HorizontalAlignment="Left" Margin="43,0,0,0" VerticalAlignment="Center"/>
        <CheckBox x:Name="cb_bush" Content="套管" HorizontalAlignment="Left" Margin="232,0,0,0" VerticalAlignment="Center"/>

    </Grid>
