<Window x:Class="CreateMaskByHeight.CreatMaskWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CreateMaskByHeight"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400" Width="400" Height="300" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Topmost="True">
    <Grid>
        <ComboBox Name="CreateType" HorizontalAlignment="Left" Margin="161,38,0,0" VerticalAlignment="Top" Width="120" >
            <ComboBoxItem Content="车道" IsSelected="True"/>
            <ComboBoxItem Content="车位"/>
            <ComboBoxItem Content="房间"/>
        </ComboBox>

        <Label Content="创建类型:" HorizontalAlignment="Left" Margin="95,36,0,0" VerticalAlignment="Top"/>
        <Label Content="最小值:" HorizontalAlignment="Left" Margin="95,94,0,0" VerticalAlignment="Top"/>
        <TextBox Name="MinValue" HorizontalAlignment="Left" Margin="161,98,0,0" TextWrapping="Wrap" Text="0" VerticalAlignment="Top" Width="120"/>
        <Label Content="最大值:" HorizontalAlignment="Left" Margin="95,148,0,0" VerticalAlignment="Top"/>
        <TextBox Name="MaxValue" HorizontalAlignment="Left" Margin="161,152,0,0" TextWrapping="Wrap" Text="0" VerticalAlignment="Top" Width="120"/>
        <Button Content="确定" HorizontalAlignment="Center" Margin="0,200,0,0" VerticalAlignment="Top" Height="30" Width="80" Click="Button_Click"/>

    </Grid>
</Window>
