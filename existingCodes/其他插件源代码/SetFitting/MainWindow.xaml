<Window x:Class="SetFitting.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SetFitting"
        mc:Ignorable="d"
        Title="布置支吊架插件 V0.1" Height="271" Width="439" WindowStartupLocation="CenterOwner">
    <Grid RenderTransformOrigin="0.5,0.5" Margin="0,0,-24,24" HorizontalAlignment="Right" Width="465" Height="199" VerticalAlignment="Bottom">
        <Grid.RowDefinitions>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform/>
                <SkewTransform/>
                <RotateTransform Angle="0.002"/>
                <TranslateTransform X="0" Y="-0.002"/>
            </TransformGroup>
        </Grid.RenderTransform>
        <Label Content="吊架间距" HorizontalAlignment="Left" Margin="36,3,0,169" RenderTransformOrigin="0.5,0.5" Width="65" FontStretch="Expanded"/>
        <TextBox x:Name="Text_btwSpace" Margin="181,7,152,0" TextWrapping="Wrap" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5" Height="27" TextChanged="TextBox_TextChanged"/>
        <Button x:Name="Btn_OK" Content="创建" HorizontalAlignment="Left" Margin="105,135,0,0" VerticalAlignment="Top" Width="37" IsDefault="True" Click="Button_Click" Height="19"/>
        <Button x:Name="Btn_Cancel" Content="取消" HorizontalAlignment="Center" Margin="0,135,0,0" VerticalAlignment="Top" Width="37"  IsCancel="True" Click="btn_Cancel_Click" Height="19"/>
        <ComboBox x:Name="Cbx_Type" HorizontalAlignment="Right" Margin="0,49,152,0" VerticalAlignment="Top" Width="130" SelectionChanged="Cbx_Type_SelectionChanged" IsReadOnly="True" Height="22"  />
        <Label Content="中心创建支吊架种类" HorizontalAlignment="Left" Margin="36,44,0,129"/>
        <Label Content="中心点位置" HorizontalAlignment="Left" Margin="36,0,0,0" Height="24" VerticalAlignment="Center"/>
        <ComboBox x:Name="Cbx_origin" VerticalAlignment="Center" IsReadOnly="True" Height="20" RenderTransformOrigin="0.5,0.5" Margin="183,0,152,0"/>


    </Grid>
</Window>
